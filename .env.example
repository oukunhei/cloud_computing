# Path to the admin kubeconfig on the host running Docker Compose.
# K3s default:
KUBECONFIG_HOST_PATH=/etc/rancher/k3s/k3s.yaml
# Optional: mount host kubectl into the container as a no-network fallback.
# Common paths: /usr/local/bin/kubectl, /usr/bin/kubectl
HOST_KUBECTL_PATH=/usr/local/bin/kubectl

# Portal settings
FLASK_PORT=8080
USER_NAMESPACE=lab-platform-users
SECRET_KEY=change-this-for-demo
# Optional public URL for remote deployments. If empty, start-lab-platform.sh
# tries to detect the server's public IP and uses http://<ip>:<FLASK_PORT>.
PUBLIC_BASE_URL=
GRAFANA_PUBLIC_BASE_URL=/grafana
GRAFANA_ROOT_URL=
GRAFANA_INTERNAL_BASE_URL=http://127.0.0.1:3000
PROMETHEUS_INTERNAL_BASE_URL=http://127.0.0.1:9090
PORTAL_METRICS_BASE_URL=http://127.0.0.1:8080

# kubectl download settings used during Docker build and runtime fallback.
# If dl.k8s.io is unstable in your network, try:
# KUBECTL_BASE_URL=https://mirrors.aliyun.com/kubernetes-release/release
KUBECTL_VERSION=v1.30.6
KUBECTL_BASE_URL=https://dl.k8s.io/release
# auto: install at container startup only if kubectl is still missing.
# always: always try runtime install if missing.
# never: never try network install at runtime.
RUNTIME_KUBECTL_INSTALL=auto
